{
  "name": "@hajicli/cli",
  "version": "1.0.0",
  "description": "Interactive CLI terminal frontend for hajicli",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "haji": "./dist/index.js"
