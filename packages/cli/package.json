{
  "name": "@hajicli/cli",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "description": "Interactive CLI terminal frontend for hajicli",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.18.1"
  },
  "bin": {
    "haji": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@hajicli/core": "workspace:^",
    "@hajicli/plugins": "workspace:^"
  }
}
